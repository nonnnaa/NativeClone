<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/banner_native_ad"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ad_banner_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ad_native_bg"
        android:padding="8dp">

        <!-- App Icon: square aspect ratio, fits height of 40dp -->
        <FrameLayout
            android:id="@+id/icon_container"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_rounded"
            android:clipToOutline="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ad_app_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Ad Icon" />
        </FrameLayout>

        <!-- Ad Badge -->
        <TextView
            android:id="@+id/tv_ad_badge"
            style="@style/Native.AdIcon"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/icon_container"
            app:layout_constraintTop_toTopOf="@id/icon_container" />

        <!-- Headline -->
        <TextView
            android:id="@+id/ad_headline"
            style="@style/Native.AdHeadline"
            android:layout_width="0dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="8dp"
            android:textSize="12sp"
            android:textColor="@color/headline_text_color"
            app:layout_constraintBottom_toBottomOf="@id/tv_ad_badge"
            app:layout_constraintEnd_toStartOf="@id/ad_call_to_action"
            app:layout_constraintStart_toEndOf="@id/tv_ad_badge"
            app:layout_constraintTop_toTopOf="@id/tv_ad_badge" />

        <!-- Body -->
        <TextView
            android:id="@+id/ad_body"
            style="@style/Native.AdBody"
            android:layout_width="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="2dp"
            android:textSize="10sp"
            android:textColor="@color/body_text_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ad_call_to_action"
            app:layout_constraintStart_toEndOf="@id/icon_container"
            app:layout_constraintTop_toBottomOf="@id/tv_ad_badge"
            app:layout_constraintVertical_bias="0.0" />

        <!-- CTA Button: fixed height 32dp -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/ad_call_to_action"
            style="@style/Native.AdButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:minWidth="72dp"
            android:minHeight="0dp"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.gms.ads.nativead.NativeAdView>