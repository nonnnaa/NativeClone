<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello World!"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
<!--    test native 1-->
<!--    <Button-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:text="Click Me to Load Native "-->
<!--        android:id="@+id/btnLoadNative"-->
<!--        app:layout_constraintTop_toBottomOf="@id/textView"-->
<!--        app:layout_constraintStart_toStartOf="parent"-->
<!--        app:layout_constraintEnd_toEndOf="parent">-->
<!--    </Button>-->
<!--    test overlay-->
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Show Overlay View "
        android:id="@+id/btnTestOverlay"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </Button>
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remove Overlay View "
        android:id="@+id/btnRemoveOverlay"
        app:layout_constraintTop_toBottomOf="@id/btnTestOverlay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </Button>
<!--    test native2-->
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Load Native Ad "
        android:id="@+id/btnLoadNativeAd"
        app:layout_constraintTop_toBottomOf="@id/btnRemoveOverlay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </Button>
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Show Native Ad "
        android:id="@+id/btnShowNativeAd"
        app:layout_constraintTop_toBottomOf="@id/btnLoadNativeAd"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </Button>
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Destroy Native Ad "
        android:id="@+id/btnDestroyNativeAd"
        app:layout_constraintTop_toBottomOf="@id/btnShowNativeAd"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </Button>

</androidx.constraintlayout.widget.ConstraintLayout>